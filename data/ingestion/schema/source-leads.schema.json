{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ecosystem-intelligence.local/schemas/source-leads.schema.json",
  "title": "Ecosystem Intelligence Source Leads",
  "description": "Pre-ingestion source discovery output. Source leads are not database records until promoted into a candidate batch.",
  "type": "object",
  "additionalProperties": false,
  "required": ["leadBatchId", "createdAt", "scope", "leads"],
  "properties": {
    "leadBatchId": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]+$"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["description", "targetUseCases", "targetDomains"],
      "properties": {
        "description": {
          "type": "string",
          "minLength": 20
        },
        "targetUseCases": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "targetDomains": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        }
      }
    },
    "leads": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "organizationName",
          "candidateCapabilityName",
          "sourceUrl",
          "sourceTitle",
          "publisher",
          "sourceType",
          "publishedAt",
          "leadSummary",
          "possibleUseCaseIds",
          "possibleDomainIds",
          "confidence",
          "followUpQuestions",
          "doNotIngestReason"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]+$"
          },
          "organizationName": {
            "type": "string",
            "minLength": 2
          },
          "candidateCapabilityName": {
            "type": ["string", "null"]
          },
          "sourceUrl": {
            "type": "string",
            "format": "uri",
            "pattern": "^https://"
          },
          "sourceTitle": {
            "type": "string",
            "minLength": 8
          },
          "publisher": {
            "type": "string",
            "minLength": 2
          },
          "sourceType": {
            "enum": ["company_website", "company_news", "government_program", "government_policy", "industry_news", "official_report"]
          },
          "publishedAt": {
            "type": ["string", "null"],
            "format": "date-time"
          },
          "leadSummary": {
            "type": "string",
            "minLength": 40
          },
          "possibleUseCaseIds": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "uniqueItems": true
          },
          "possibleDomainIds": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "uniqueItems": true
          },
          "confidence": {
            "enum": ["high", "moderate", "needs_validation", "reject"]
          },
          "followUpQuestions": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "doNotIngestReason": {
            "type": ["string", "null"]
          }
        }
      }
    }
  }
}
